APP_ENV=development
SECRETS_ENCRYPTION_KEY=replace-with-a-long-random-secret
PUBLIC_API_BASE_URL=http://localhost:8080
BOOTSTRAP_API_KEY=lmai_dev_key
AUTH_EXEMPT_PATHS=/v1/health,/docs,/openapi.json,/redoc

# ── Database ────────────────────────────────────────────────────────
# Option A — Local Docker mongo (default; start with: docker compose --profile local up)
MONGODB_URL=mongodb://mongo:27017
# Option B — MongoDB Atlas (obtain connection string from Atlas → Connect → Drivers)
# MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=litmusai

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Routing ─────────────────────────────────────────────────────
# Set LLM_PROVIDER + LLM_MODEL, then fill in the matching API key below.
#
# Gemini:    LLM_PROVIDER=gemini    LLM_MODEL=gemini/gemini-2.0-flash
# Anthropic: LLM_PROVIDER=anthropic LLM_MODEL=anthropic/claude-haiku-4-5-20251001
# OpenAI:    LLM_PROVIDER=openai    LLM_MODEL=openai/gpt-4o-mini
# LM Studio: LLM_PROVIDER=lmstudio  (uses LMSTUDIO_BASE_URL + LMSTUDIO_MODEL)
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash

# ── Provider API Keys ───────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── LM Studio (local endpoint) ──────────────────────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=gemma4
